#!/usr/bin/env python3
"""
bacon-statusline — renders ONE frame of the animated sponsor segment.

Claude Code calls this every `refreshInterval` seconds (min 1s). Each call
returns the next frame. Frame state (the tick counter) is stored in a temp
file since each invocation is a fresh process.

Two animation styles:
  --style marquee   scrolling text through a fixed window
  --style sweep     a light sweeping left→right across the segment
  --style pulse     the logo/name pulsing brighter/dimmer (color)

Usage (Claude Code statusline command):  bacon-statusline
Demo (print N frames as a filmstrip):    bacon-statusline --demo 12
"""

import json
import os
import subprocess
import sys
import time
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import bacon_core

CONFIG_DIR = Path.home() / ".bacon"
CONFIG_FILE = CONFIG_DIR / "config.json"
STATE = CONFIG_DIR / "sl_tick"
FRAME_FILE = CONFIG_DIR / "sl_frame"   # pre-rendered frame for fast-path shell cat
SL_AD_FILE = CONFIG_DIR / "statusline_ad.json"
SL_VIEW_FILE = CONFIG_DIR / "sl_view.json"
BALANCE_FILE = CONFIG_DIR / "balance.json"

# How many consecutive renders of the same impression before buffering a view
VIEW_THRESHOLD_FRAMES = 3

# ANSI
DIM = "\033[2m"; BOLD = "\033[1m"; RESET = "\033[0m"
YEL = "\033[93m"; CYAN = "\033[96m"; GRN = "\033[92m"; ORANGE = "\033[38;5;208m"

# OSC 8 hyperlink sequences
def osc8(url, text):
    """Wrap text in an OSC 8 hyperlink (terminal-clickable link)."""
    if not url:
        return text
    ESC = "\033"
    return f"{ESC}]8;;{url}{ESC}\\{text}{ESC}]8;;{ESC}\\"

# Demo fixture — only used when --demo is passed
DEMO_SPONSOR = {
    "logo": "☕",
    "name": "BYTE & BREW",
    "tagline": "the dev cafe · bottomless cold brew · byteandbrew.cafe",
    "url": "",
}

WINDOW = 34  # visible character window for the scrolling marquee


# ---------------------------------------------------------------------------
# Config / cache helpers
# ---------------------------------------------------------------------------

def load_config():
    try:
        if not CONFIG_FILE.exists():
            return {}
        return json.loads(CONFIG_FILE.read_text())
    except Exception:
        return {}


def load_statusline_ad():
    """Return the cached statusline ad dict, or None if missing/unreadable."""
    try:
        if not SL_AD_FILE.exists():
            return None
        return json.loads(SL_AD_FILE.read_text())
    except Exception:
        return None


def is_fresh(ad, ttl):
    """True if ad was written within ttl seconds."""
    try:
        return (time.time() - ad["ts"]) <= ttl
    except Exception:
        return False


def load_balance():
    """Return balance float from cache, or None."""
    try:
        if not BALANCE_FILE.exists():
            return None
        data = json.loads(BALANCE_FILE.read_text())
        return data.get("balance")
    except Exception:
        return None


# ---------------------------------------------------------------------------
# Tick / frame counter
# ---------------------------------------------------------------------------

def next_tick():
    try:
        t = int(STATE.read_text().strip())
    except Exception:
        t = 0
    try:
        STATE.write_text(str(t + 1))
    except Exception:
        pass
    return t


# ---------------------------------------------------------------------------
# Frame renderers
# ---------------------------------------------------------------------------

MARQUEE_STEP = 1.0  # avg chars the marquee advances per frame (higher = faster)


def frame_marquee(tick, sp):
    """Scroll the tagline through a fixed window."""
    text = f"{sp['logo']}  {sp['name']} — {sp['tagline']}    "
    n = len(text)
    start = int(tick * MARQUEE_STEP) % n
    window = (text + text)[start:start + WINDOW]
    return f"{ORANGE}🥓 Sponsored{RESET} {DIM}│{RESET} {YEL}{window}{RESET}"


def frame_sweep(tick, sp):
    """A light dot sweeping left→right after the sponsor name."""
    track_len = 12
    pos = tick % track_len
    track = "".join("▸" if i == pos else "·" for i in range(track_len))
    return (f"{ORANGE}🥓 Sponsored{RESET} {sp['logo']} {BOLD}{sp['name']}{RESET} "
            f"{CYAN}{track}{RESET}")


def frame_pulse(tick, sp):
    """Pulse the name brightness in a cycle."""
    cycle = ["\033[2m", "\033[0m", "\033[1m", "\033[1;93m", "\033[1m", "\033[0m"]
    style = cycle[tick % len(cycle)]
    return (f"{ORANGE}🥓 Sponsored{RESET} {sp['logo']} "
            f"{style}{sp['name']}{RESET} {DIM}· {sp['tagline']}{RESET}")


STYLES = {"marquee": frame_marquee, "sweep": frame_sweep, "pulse": frame_pulse}


# ---------------------------------------------------------------------------
# View-threshold tracker (zero network)
# ---------------------------------------------------------------------------

def maybe_report_view(ad, config):
    """
    Track per-impression render count in sl_view.json.
    When n == VIEW_THRESHOLD_FRAMES, buffer the report via bacon_core.
    The buffer deduplicates by impression_id so extra calls are harmless.
    Always fail-open.
    """
    try:
        impression_id = ad.get("impression_id", "")
        if not impression_id:
            return

        # Load current view state
        try:
            view = json.loads(SL_VIEW_FILE.read_text()) if SL_VIEW_FILE.exists() else {}
        except Exception:
            view = {}

        stored_id = view.get("impression_id", "")
        n = view.get("n", 0)

        if stored_id != impression_id:
            # New impression — reset counter
            n = 1
        else:
            n += 1

        # Persist updated state
        try:
            SL_VIEW_FILE.write_text(json.dumps({"impression_id": impression_id, "n": n}))
        except Exception:
            pass

        # Buffer the report at the threshold (once per impression_id)
        if n == VIEW_THRESHOLD_FRAMES:
            bacon_core.buffer_report({
                "user_id": config.get("user_id"),
                "impression_id": impression_id,
                "impression_token": ad.get("impression_token", ""),
                "campaign_id": ad.get("campaign_id", ""),
                "surface": "statusline",
            })
    except Exception:
        pass  # never break the statusline


# ---------------------------------------------------------------------------
# Detached refresher spawn
# ---------------------------------------------------------------------------

def spawn_refresh():
    """Spawn bacon-refresh --surface statusline detached. Fail-open."""
    try:
        refresher = Path(__file__).parent / "bacon-refresh"
        subprocess.Popen(
            [sys.executable, str(refresher), "--surface", "statusline"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception:
        pass


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    args = sys.argv[1:]
    style = "marquee"
    if "--style" in args:
        style = args[args.index("--style") + 1]
    render = STYLES.get(style, frame_marquee)

    if "--demo" in args:
        # Filmstrip: print N consecutive frames so the motion is visible
        # without a live 1fps TTY.
        n = int(args[args.index("--demo") + 1])
        for label, fn in STYLES.items():
            print(f"\n=== style: {label} ({n} frames, 1 per second live) ===")
            for t in range(n):
                print(f"  t{t:<2} {fn(t, DEMO_SPONSOR)}")
        return

    # Read the session JSON Claude Code passes on stdin (needed to forward to a
    # wrapped statusline). Read it once, up front.
    stdin_data = ""
    if not sys.stdin.isatty():
        try:
            stdin_data = sys.stdin.read()
        except Exception:
            stdin_data = ""

    # --wrap "<command>": run the user's existing statusline first, print its
    # output, then append the Bacon segment. This is how we add to a statusline
    # without clobbering the user's context/git/cost display.
    wrapped_original = None
    if "--wrap" in args:
        inner = args[args.index("--wrap") + 1]
        # shell=True is intentional and matches Claude Code's own behavior: a
        # statusLine.command is a shell-string (e.g. "cd $dir && git branch"),
        # and `inner` is the user's OWN prior statusline command that we captured
        # from their settings.json during setup — not external/attacker input.
        # Splitting into argv would break shell statuslines.
        try:
            proc = subprocess.run(inner, shell=True, input=stdin_data,  # noqa: S602
                                  capture_output=True, text=True, timeout=3)
            wrapped_original = proc.stdout.rstrip("\n")
        except Exception:
            wrapped_original = None

    # Print the wrapped original line first if we have one
    if wrapped_original:
        print(wrapped_original)

    # --- Load config and cached ad ---
    config = {}
    ad = None
    try:
        config = load_config()
        ttl = config.get("cache_ttl_sec", 180)
        cached_ad = load_statusline_ad()
        if cached_ad and is_fresh(cached_ad, ttl):
            ad = cached_ad
    except Exception:
        pass

    if ad is None:
        # No fresh ad: spawn refresher for next time, output nothing for the
        # bacon segment (never show stale/empty).
        spawn_refresh()
        return

    # Build sponsor dict from the cached ad
    sp = {
        "logo": ad.get("logo", "🥓"),
        "name": ad.get("advertiser", "Sponsor"),
        "tagline": ad.get("tagline") or ad.get("ad_text", ""),
        "url": ad.get("url", ""),
    }

    tick = next_tick()
    segment = render(tick, sp)

    # Wrap the sponsor segment's visible text in an OSC 8 hyperlink if url present
    ad_url = ad.get("url", "")
    if ad_url:
        segment = osc8(ad_url, segment)

    # Append balance (dimmed) if available
    balance = load_balance()
    if balance is not None:
        try:
            segment = f"{segment}  {DIM}Bacon ${balance:.4f}{RESET}"
        except Exception:
            pass

    print(segment)

    # Cache the rendered frame so the shell fast-path can cat it next tick
    try:
        FRAME_FILE.write_text(segment)
    except Exception:
        pass

    # View-threshold reporting (buffered locally, after printing so render is never delayed)
    maybe_report_view(ad, config)


if __name__ == "__main__":
    try:
        main()
    except Exception:
        sys.exit(0)
