#!/usr/bin/env python3
"""
bacon-refresh — detached, fail-open ad refresher for non-context surfaces.

Selects a winner from the local campaign cache and writes the result to
~/.bacon/<surface>_ad.json. Called by bacon-statusline when the cached ad is
stale or missing; always runs detached and never blocks the caller.
Zero network on the hot path — all network goes through bacon-refill.

Usage:
  bacon-refresh --surface statusline
"""

import json
import os
import sys
import time
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import bacon_core

CONFIG_DIR = Path.home() / ".bacon"


def main():
    args = sys.argv[1:]

    # Parse --surface
    surface = "statusline"
    if "--surface" in args:
        idx = args.index("--surface")
        if idx + 1 < len(args):
            surface = args[idx + 1]

    config = bacon_core.load_config()
    if not config or not config.get("active", False):
        sys.exit(0)

    campaigns = bacon_core.load_campaigns()
    # Statusline has no prompt intent — use untargeted / highest-priority selection
    winner = bacon_core.select_winner(campaigns, set())
    if not winner:
        bacon_core.spawn_refill()
        sys.exit(0)

    tok = bacon_core.pop_token()
    if not tok:
        bacon_core.spawn_refill()
        sys.exit(0)

    # Write surface-specific ad cache
    try:
        CONFIG_DIR.mkdir(exist_ok=True)
        cache = {
            "ad_text":          winner.get("ad_text", ""),
            "advertiser":       winner.get("advertiser", ""),
            "tier":             winner.get("tier", "strip"),
            "logo":             winner.get("logo", ""),
            "tagline":          winner.get("tagline", ""),
            "url":              winner.get("url", ""),
            "campaign_id":      winner["id"],
            "impression_id":    tok["impression_id"],
            "impression_token": tok["token"],
            "ts":               time.time(),
        }
        cache_file = CONFIG_DIR / f"{surface}_ad.json"
        cache_file.write_text(json.dumps(cache))
    except Exception:
        pass

    if bacon_core.tokens_low(config) or bacon_core.campaigns_stale(config):
        bacon_core.spawn_refill()

    sys.exit(0)


if __name__ == "__main__":
    try:
        main()
    except Exception:
        sys.exit(0)
