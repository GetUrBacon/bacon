#!/usr/bin/env python3
"""
bacon-config — developer control over the ads they see.

The config lives at ~/.bacon/config.json and governs what bacon-fetch requests
and renders. Controls:

  frequency      how often ads show          minimal|standard|more|max|every
  profile        targeting data shared        anonymous|stack|full
  inreply        in-reply ad surface          on|off  (format is set by the
                                              advertiser's campaign, not you)
  block/unblock  mute categories/advertisers  e.g. crypto, food, ZapLogin
  pause/resume   master on/off switch

The statusline and spinner ("thinking verb") surfaces are separate opt-ins that
edit ~/.claude/settings.json — enable them via `bacon-setup statusline-enable`
and `bacon-setup spinner-enable`.

Usage:
  bacon-config show
  bacon-config frequency <minimal|standard|more|max|every>
  bacon-config profile   <anonymous|stack|full>
  bacon-config inreply   <on|off>
  bacon-config block     <category-or-advertiser>
  bacon-config unblock   <category-or-advertiser>
  bacon-config pause
  bacon-config resume
"""

import json
import sys
from pathlib import Path

CONFIG_DIR = Path.home() / ".bacon"
CONFIG_FILE = CONFIG_DIR / "config.json"

FREQ_MAP = {"minimal": 20, "standard": 10, "more": 5, "max": 2, "every": 1}
PROFILE_TIERS = ["anonymous", "stack", "full"]
CLAUDE_SETTINGS = Path.home() / ".claude" / "settings.json"

# Rough earnings estimate baseline at 500 prompts/day — for show output.
# Deliberately tier-independent: payout derives from the advertiser's bid (server
# side), not the user's profile tier. A higher tier means more *relevant* ads,
# which *may* earn more via better-targeted (higher-bid) campaigns — but there is
# no guaranteed fixed multiplier, so we don't promise one in the estimate.
BASE_CPM = 1.0

DEFAULTS = {
    "user_id": "",
    "active": True,
    "frequency_tier": "standard",
    "frequency": 10,
    "profile_tier": "anonymous",
    "inreply_enabled": True,
    "blocked_categories": [],
    "blocked_advertisers": [],
    "cache_ttl_sec": 180,
    "spinner_enabled": False,
    "spinner_style": "default",
    "token_bucket_target": 50,
    "campaigns_ttl_sec": 600,
    "refill_low_watermark": 10,
}


def load():
    CONFIG_DIR.mkdir(exist_ok=True)
    if CONFIG_FILE.exists():
        try:
            cfg = json.loads(CONFIG_FILE.read_text())
        except Exception:
            cfg = {}
    else:
        cfg = {}
    # Backfill defaults without clobbering existing values (e.g. auction_url)
    for k, v in DEFAULTS.items():
        cfg.setdefault(k, v)
    return cfg


def save(cfg):
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))


def est_monthly(freq_tier):
    per_day = 500 / FREQ_MAP[freq_tier]
    return per_day * 30 / 1000 * BASE_CPM * 0.5  # developer 50% cut


def statusline_on():
    """True if the Bacon statusline is wired into ~/.claude/settings.json."""
    try:
        return "bacon-statusline" in CLAUDE_SETTINGS.read_text()
    except Exception:
        return False


def cmd_show(cfg):
    print("🥓 Bacon — your ad settings")
    print("─" * 42)
    state = "active" if cfg["active"] else "PAUSED"
    print(f"  Status:       {state}")
    print(f"  Frequency:    {cfg['frequency_tier']} (1 per {cfg['frequency']} prompts)")
    print(f"  Profile:      {cfg['profile_tier']}")
    print("  Surfaces:")
    print(f"    In-reply:   {'on' if cfg.get('inreply_enabled', True) else 'off'}  "
          f"(format chosen by the advertiser)")
    print(f"    Statusline: {'on' if statusline_on() else 'off'}  "
          f"(bacon-setup statusline-enable)")
    print(f"    Spinner:    {'on' if cfg.get('spinner_enabled') else 'off'}  "
          f"(bacon-setup spinner-enable)")
    bc = ", ".join(cfg["blocked_categories"]) or "none"
    ba = ", ".join(cfg["blocked_advertisers"]) or "none"
    print(f"  Blocked cats: {bc}")
    print(f"  Blocked advs: {ba}")
    print("─" * 42)
    est = est_monthly(cfg["frequency_tier"])
    print(f"  Est. earnings: ~${est:.2f}/mo  (rough, at 500 prompts/day)")
    print("─" * 42)


def cmd_frequency(cfg, val):
    if val not in FREQ_MAP:
        print(f"Invalid. Choose: {', '.join(FREQ_MAP)}"); return
    cfg["frequency_tier"] = val
    cfg["frequency"] = FREQ_MAP[val]
    save(cfg)
    print(f"✅ Frequency → {val} (1 per {FREQ_MAP[val]} prompts). "
          f"Est. ~${est_monthly(val):.2f}/mo")


def cmd_profile(cfg, val):
    if val not in PROFILE_TIERS:
        print(f"Invalid. Choose: {', '.join(PROFILE_TIERS)}"); return
    cfg["profile_tier"] = val
    save(cfg)
    note = {
        "anonymous": "no data shared — random ads",
        "stack": "languages/deps shared — more relevant ads",
        "full": "stack + domain shared — most relevant ads",
    }[val]
    print(f"✅ Profile → {val} ({note}). More relevant ads may earn more via "
          f"better-targeted campaigns. Your prompts/code are never shared.")


def cmd_inreply(cfg, val):
    val = val.strip().lower()
    if val not in ("on", "off"):
        print("Invalid. Choose: on | off"); return
    cfg["inreply_enabled"] = (val == "on")
    save(cfg)
    if val == "on":
        print("✅ In-reply ads → on. Format (strip/card/banner) is set by the "
              "advertiser's campaign, not a setting you pick.")
    else:
        print("✅ In-reply ads → off. Enable statusline/spinner surfaces with "
              "bacon-setup statusline-enable / spinner-enable.")


def cmd_block(cfg, val, on):
    val = val.strip()
    # Heuristic: lowercase single word with no spaces and a known category → category
    cat_list = "blocked_categories"
    adv_list = "blocked_advertisers"
    known_cats = {"auth", "database", "payments", "infra", "monitoring",
                  "testing", "cicd", "email", "search", "ai", "food", "general", "crypto"}
    target = cat_list if val.lower() in known_cats else adv_list
    key = val.lower() if target == cat_list else val
    lst = cfg[target]
    if on:
        if key not in lst:
            lst.append(key)
        print(f"✅ Blocked {'category' if target==cat_list else 'advertiser'}: {key}")
    else:
        if key in lst:
            lst.remove(key)
        print(f"✅ Unblocked: {key}")
    save(cfg)


def cmd_pause(cfg, active):
    cfg["active"] = active
    save(cfg)
    print("✅ Bacon resumed — ads on, earning again." if active
          else "✅ Bacon paused — no ads, no earnings until you resume.")


def main():
    args = sys.argv[1:]
    cfg = load()
    if not args or args[0] == "show":
        cmd_show(cfg); return
    cmd, *rest = args
    arg = rest[0] if rest else ""
    if cmd == "frequency": cmd_frequency(cfg, arg)
    elif cmd == "profile": cmd_profile(cfg, arg)
    elif cmd == "inreply": cmd_inreply(cfg, arg)
    elif cmd == "block": cmd_block(cfg, arg, on=True)
    elif cmd == "unblock": cmd_block(cfg, arg, on=False)
    elif cmd == "pause": cmd_pause(cfg, active=False)
    elif cmd == "resume": cmd_pause(cfg, active=True)
    else:
        print(f"Unknown command: {cmd}\n{__doc__}")


if __name__ == "__main__":
    main()
