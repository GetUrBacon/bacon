#!/usr/bin/env python3
"""
bacon-fetch — called by the UserPromptSubmit hook on every Claude Code request.
Selects the winning ad from the local client-side auction and returns it as
additionalContext. Falls back silently (no output, exit 0) on any error so it
never blocks Claude Code. Zero network on the hot path.
"""

import json
import os
import re
import sys
import time
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import bacon_core

CONFIG_DIR = Path.home() / ".bacon"
FREQUENCY_DEFAULT = 10  # show ad every N prompts
COUNTER_FILE = CONFIG_DIR / "counter"
SIGNAL_FILE = CONFIG_DIR / "signals.json"


def load_config():
    if not (CONFIG_DIR / "config.json").exists():
        return None
    try:
        return json.loads((CONFIG_DIR / "config.json").read_text())
    except Exception:
        return None


def get_counter():
    try:
        return int(COUNTER_FILE.read_text().strip())
    except Exception:
        return 0


def increment_counter():
    count = get_counter() + 1
    COUNTER_FILE.write_text(str(count))
    return count


def should_show_ad(config):
    frequency = config.get("frequency", FREQUENCY_DEFAULT)
    count = increment_counter()
    return count % frequency == 0


def get_context_signals():
    """Read project signals without touching prompt content."""
    signals = {
        "os": sys.platform,
        "hour": time.localtime().tm_hour,
    }

    cwd = Path.cwd()

    # Detect stack from dependency files
    for dep_file in ["package.json", "go.mod", "requirements.txt",
                     "Cargo.toml", "pyproject.toml", "composer.json"]:
        if (cwd / dep_file).exists():
            signals["dep_file"] = dep_file
            break

    # Detect dominant file type
    try:
        exts = [f.suffix for f in cwd.iterdir()
                if f.is_file() and f.suffix]
        if exts:
            signals["ext"] = max(set(exts), key=exts.count)
    except Exception:
        pass

    return signals


def get_intent_signals():
    """Read locally-derived signals from bacon-signal. Never contains raw content."""
    try:
        if not SIGNAL_FILE.exists():
            return []
        raw = json.loads(SIGNAL_FILE.read_text())
        # Consume signals — clear after reading so they don't repeat
        SIGNAL_FILE.write_text("[]")
        return raw[-10:]  # last 10 signals for this auction
    except Exception:
        return []


PROMPT_INTENT_PATTERNS = [
    (r"auth|oauth|jwt|login|signup|password|sign.?in", "intent_auth"),
    (r"postgres|mysql|sqlite|mongodb|redis|prisma|database|\bdb\b|orm", "intent_database"),
    (r"docker|kubernetes|k8s|terraform|deploy|aws|gcp|azure|server", "intent_infra"),
    (r"stripe|payment|billing|subscription|checkout|webhook", "intent_payments"),
    (r"sentry|monitor|logging|observability|error.*track", "intent_monitoring"),
    (r"jest|pytest|vitest|playwright|cypress|\btest", "intent_testing"),
    (r"coffee|caffeine|tired|exhausted|sleep|awake|all night|3am|all.?nighter|break", "intent_coffee"),
]


def detect_prompt_intent(prompt_text):
    """Derive intent labels from the user's prompt text."""
    signals = []
    text = (prompt_text or "").lower()
    for pattern, label in PROMPT_INTENT_PATTERNS:
        if re.search(pattern, text):
            signals.append({"type": "intent", "label": label})
    return signals


def read_prompt_from_stdin():
    """UserPromptSubmit hook passes the prompt as JSON on stdin."""
    try:
        data = json.loads(sys.stdin.read())
        return data.get("prompt", "")
    except Exception:
        return ""


# ---------------------------------------------------------------------------
# Tier renderers — the three ad formats
# ---------------------------------------------------------------------------

def _link_target(ad, surface):
    """The UTM-tagged advertiser URL used as a markdown-link target. UTMs live
    here (the target) only — never in the visible host text."""
    return bacon_core.append_utm_params(ad.get("url", ""), surface, ad.get("id", ""))


def render_strip(ad):
    """Tier 1 — single labeled line. Cheapest, least intrusive.

    Format: `🥓 Sponsored │ {logo} {name} — {message} → [host](url)`, mirroring the
    statusline and inline_mention surfaces so every format shows logo + advertiser
    + message and is clickable. The leading "🥓 Sponsored" stays the first-thing
    disclosure; the visible host text is clean, UTMs live on the link target only."""
    logo = ad.get("logo", "🥓")
    name = ad.get("advertiser", "")
    msg = ad.get("ad_text", "")
    raw = ad.get("url", "")
    host = raw.replace("https://", "").replace("http://", "")
    head = f"🥓 Sponsored │ {logo} {name} — {msg}" if name else f"🥓 Sponsored │ {logo} {msg}"
    if raw:
        # Markdown link → CC renders [host](https) as a clickable OSC 8 link (same
        # as card/inline). UTMs go on the target only, never the visible host.
        head += f" → [{host}]({_link_target(ad, 'strip')})"
    return head


def render_card(ad):
    """Tier 2 — left-rule block. No right border, so emoji width can never
    break alignment (the trick npm/cargo/vercel use)."""
    logo = ad.get("logo", "🥓")
    name = ad.get("advertiser", "")
    tagline = ad.get("tagline", "") or ad["ad_text"]
    raw = ad.get("url", "")
    host = raw.replace("https://", "").replace("http://", "")
    lines = [
        "🥓 Sponsored",
        f"{logo} {name}",
        f"   {tagline}",
    ]
    if raw:
        # Markdown link: visible text = clean host, target = UTM'd url. CC's
        # renderer turns [host](https) into a clickable OSC 8 link. Best-effort
        # for card/marquee — if the model code-fences this block the link won't
        # render (revert to plain `→ host` if live testing shows fencing).
        lines.append(f"   → [{host}]({_link_target(ad, 'card')})")
    return "\n".join(f"│ {l}" for l in lines)


def render_banner(ad):
    """Tier 3 — premium static banner. Heavier left rule with top/bottom caps.
    Still no right border (alignment-safe). This is the 'big' tier — true
    animation isn't possible because Claude Code hooks can't draw to the TTY."""
    logo = ad.get("logo", "🥓")
    name = ad.get("advertiser", "")
    tagline = ad.get("tagline", "") or ad["ad_text"]
    raw = ad.get("url", "")
    host = raw.replace("https://", "").replace("http://", "")
    out = [
        "┏━━ 🥓 Sponsored ━━━━━━━━━━━━━━━━",
        f"┃  {logo}  {name.upper()}",
        f"┃  {tagline}",
    ]
    if raw:
        # Best-effort markdown link (see render_card note on fencing).
        out.append(f"┃  → [{host}]({_link_target(ad, 'marquee')})")
    out.append("┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    return "\n".join(out)


def render_inline(ad):
    """inline_mention — a clearly-labeled, set-apart block placed where it's
    contextually relevant in the reply (a markdown blockquote), NOT woven into the
    assistant's own prose. The leading "🥓 Sponsored" label is the disclosure and
    must come first. Honest-by-design per FTC native-ad guidance + the inline-ad
    research: an ad that reads like impartial advice needs a clear, prominent,
    pre-message label — so we never blend it into a sentence."""
    logo = ad.get("logo", "🥓")
    name = ad.get("advertiser", "")
    tagline = ad.get("tagline", "") or ad["ad_text"]
    raw = ad.get("url", "")
    host = raw.replace("https://", "").replace("http://", "")
    line = f"> 🥓 Sponsored · {logo} {name} — {tagline}"
    if raw:
        # Single blockquote line — low fence risk, reliably clickable. Visible
        # text = clean host, target = UTM'd url.
        line += f" → [{host}]({_link_target(ad, 'inline_mention')})"
    return line


def main():
    config = load_config()
    if not config or not config.get("active", False):
        sys.exit(0)

    # In-reply is its own opt-in surface (default on). A user can run
    # statusline/spinner-only by turning this off while staying active.
    if not config.get("inreply_enabled", True):
        sys.exit(0)

    if not should_show_ad(config):
        sys.exit(0)

    prompt = read_prompt_from_stdin()

    # Build intent label set from signal file + prompt text
    raw_signals = get_intent_signals() + detect_prompt_intent(prompt)
    intent_labels = {
        s["label"] for s in raw_signals
        if isinstance(s, dict) and s.get("label")
    }

    campaigns = bacon_core.load_campaigns()
    winner = bacon_core.select_winner(campaigns, intent_labels, config)
    if not winner:
        bacon_core.spawn_refill()
        sys.exit(0)

    tok = bacon_core.pop_token()
    if not tok:
        bacon_core.spawn_refill()
        sys.exit(0)

    # Pick renderer by surface. `rendered_surface` is the surface we actually
    # print, reported to settle so the backend prices this impression at that
    # surface's rate (not a generic "context" bucket). The auction sends both
    # `surface` (canonical) and `tier` (legacy); prefer surface, fall back to
    # tier for older backends. Unknown surfaces fall back to strip.
    surface = winner.get("surface") or winner.get("tier", "strip")
    if surface == "card":
        ad_block = render_card(winner)
        rendered_surface = "card"
    elif surface == "marquee":
        ad_block = render_banner(winner)
        rendered_surface = "marquee"
    elif surface == "inline_mention":
        ad_block = render_inline(winner)
        rendered_surface = "inline_mention"
    else:
        ad_block = render_strip(winner)
        rendered_surface = "strip"

    if rendered_surface == "inline_mention":
        # Inline: place the labeled block where it's genuinely relevant in the
        # reply, but keep it set apart and disclosed — never blended into a
        # sentence or presented as the assistant's own recommendation.
        instruction = (
            "[Bacon ad network] A sponsor is relevant to this conversation. "
            "At a natural, genuinely-relevant point in your reply, include the "
            "following sponsored block on its own line(s), exactly as-is (keep the "
            "leading '🥓 Sponsored' label). Do NOT rephrase it, weave it into a "
            "sentence, or present it as your own recommendation. If nothing in your "
            "reply is relevant to it, place it at the very end instead:\n\n" + ad_block
        )
    else:
        instruction = (
            "[Bacon ad network] A sponsor is relevant to this conversation. "
            "At the very end of your reply, reproduce the following sponsored block "
            "exactly as-is on its own lines, then stop:\n\n" + ad_block
        )

    output = {
        "hookSpecificOutput": {
            "hookEventName": "UserPromptSubmit",
            "additionalContext": instruction,
        }
    }
    # Print hook output FIRST — Claude must never be delayed by reporting
    print(json.dumps(output))

    # Buffer the impression report locally — zero network
    bacon_core.buffer_report({
        "user_id": config.get("user_id"),
        "impression_id": tok["impression_id"],
        "impression_token": tok["token"],
        "campaign_id": winner["id"],
        "surface": rendered_surface,
    })

    # Trigger background refill if running low
    if bacon_core.tokens_low(config) or bacon_core.campaigns_stale(config):
        bacon_core.spawn_refill()


if __name__ == "__main__":
    main()
