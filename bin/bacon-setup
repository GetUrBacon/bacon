#!/usr/bin/env python3
"""
bacon-setup — first-run onboarding + statusline/spinner management.

Most settings (frequency/profile/surface/blocklist) are handled by bacon-config.
bacon-setup owns the things bacon-config doesn't:
  - account/config bootstrap (init)
  - the CONSENTED edit to ~/.claude/settings.json to enable the statusline ad
    (wrap-don't-clobber: preserves any existing statusline)
  - clean uninstall (restores the original statusline)
  - the CONSENTED edit to ~/.claude/settings.json to enable the spinnerVerbs ad
    (the "thinking" verb surface; written per-session by the SessionStart hook)

Commands:
  bacon-setup login                  connect your Bacon account via Clerk OAuth PKCE
  bacon-setup status                 show whether Bacon is configured + active
  bacon-setup init [--user-id X]     create ~/.bacon/config.json with defaults
  bacon-setup statusline-enable [--style marquee|sweep|pulse]
                                     add Bacon to ~/.claude/settings.json,
                                     wrapping any existing statusline. The
                                     animated sponsor segment appears in the
                                     Claude Code status bar — no ads injected
                                     into Claude's replies when using this mode.
  bacon-setup statusline-disable     restore the original statusline
  bacon-setup spinner-enable [--style default]
                                     enable the spinnerVerbs thinking-verb ad;
                                     the verb appears from the next CC session
  bacon-setup spinner-disable        disable the spinner ad, restore original
                                     spinnerVerbs (if any)
  bacon-setup uninstall              disable all surfaces + deactivate config

This command edits the user's ~/.claude/settings.json. It is meant to be run BY
THE USER (or with explicit consent), never silently.
"""

import base64
import hashlib
import http.server
import json
import secrets
import socket
import sys
import threading
import urllib.parse
import urllib.request
import uuid
import webbrowser
from pathlib import Path

BACON_DIR = Path.home() / ".bacon"
CONFIG_FILE = BACON_DIR / "config.json"
CLAUDE_SETTINGS = Path.home() / ".claude" / "settings.json"
SL_BACKUP = BACON_DIR / "statusline_backup.json"
SPINNER_BACKUP = BACON_DIR / "spinner_backup.json"
SPINNER_AD_FILE = BACON_DIR / "spinner_ad.json"

STATUSLINE_BIN = str(Path(__file__).resolve().parent / "bacon-statusline")


def _pkce_pair():
    """Return (code_verifier, code_challenge) per RFC 7636."""
    verifier = base64.urlsafe_b64encode(secrets.token_bytes(32)).rstrip(b"=").decode()
    digest = hashlib.sha256(verifier.encode()).digest()
    challenge = base64.urlsafe_b64encode(digest).rstrip(b"=").decode()
    return verifier, challenge


def _free_port():
    for _ in range(3):
        with socket.socket() as s:
            s.bind(("127.0.0.1", 0))
            port = s.getsockname()[1]
        return port
    raise OSError("No free port found")


def _run_local_server(port):
    """Start a one-shot HTTP server, return the first ?code= value or None."""
    received = []
    done = threading.Event()

    class _H(http.server.BaseHTTPRequestHandler):
        def do_GET(self):
            qs = urllib.parse.urlparse(self.path).query
            code = urllib.parse.parse_qs(qs).get("code", [""])[0]
            if code:
                received.append(code)
            self.send_response(200)
            self.send_header("Content-Type", "text/html")
            self.end_headers()
            self.wfile.write(b"<html><body><h2>Bacon connected! You can close this tab.</h2></body></html>")
            done.set()
        def log_message(self, *_):
            pass

    srv = http.server.HTTPServer(("127.0.0.1", port), _H)
    threading.Thread(target=srv.serve_forever, daemon=True).start()
    done.wait(timeout=120)
    srv.shutdown()
    return received[0] if received else None


def load_json(p, default):
    try:
        return json.loads(p.read_text())
    except Exception:
        return default


def bacon_command(style, wrap=None):
    """Build the statusLine.command string for our script."""
    cmd = f'python3 "{STATUSLINE_BIN}" --style {style}'
    if wrap:
        # Escape any double-quotes in the wrapped command
        safe = wrap.replace('"', '\\"')
        cmd += f' --wrap "{safe}"'
    return cmd


def cmd_login():
    """
    Run the Clerk OAuth PKCE flow. Returns the Clerk user_id (e.g. 'user_2abc...')
    on success, or None on cancellation/error. Always fail-open.
    """
    try:
        # Fetch OAuth config from the live backend (no hardcoded values in plugin source)
        config_url = "https://bacon-backend-production.up.railway.app/v1/auth/config"
        config_req = urllib.request.Request(
            config_url,
            headers={"User-Agent": "bacon-setup/1.0 (CLI login)"},
        )
        with urllib.request.urlopen(config_req, timeout=5) as resp:
            oauth = json.loads(resp.read())
        client_id     = oauth.get("client_id", "")
        authorize_url = oauth.get("authorize_url", "")
        token_url     = oauth.get("token_url", "")
        if not client_id or not authorize_url or not token_url:
            print("⚠️  Bacon login not configured yet. Using anonymous ID.")
            return None

        verifier, challenge = _pkce_pair()
        # Fixed port required — Clerk OAuth apps need exact redirect_uri match
        for port in [7891, 7892, 7893]:
            try:
                import socket as _s
                with _s.socket() as _sock:
                    _sock.bind(("127.0.0.1", port))
                break
            except OSError:
                continue
        else:
            print("⚠️  Could not bind to ports 7891-7893. Using anonymous ID.")
            return None
        redirect_uri = f"http://127.0.0.1:{port}/callback"

        params = urllib.parse.urlencode({
            "client_id":             client_id,
            "redirect_uri":          redirect_uri,
            "response_type":         "code",
            "code_challenge":        challenge,
            "code_challenge_method": "S256",
            "scope":                 "openid profile email",
        })
        full_url = f"{authorize_url}?{params}"
        print("🥓 Opening browser to connect your Bacon account...")
        print(f"   If it doesn't open, visit: {full_url}")
        webbrowser.open(full_url)

        code = _run_local_server(port)
        if not code:
            print("⚠️  Login timed out or was cancelled. Using anonymous ID.")
            return None

        body = urllib.parse.urlencode({
            "grant_type":    "authorization_code",
            "code":          code,
            "redirect_uri":  redirect_uri,
            "client_id":     client_id,
            "code_verifier": verifier,
        }).encode()
        req = urllib.request.Request(
            token_url,
            data=body,
            headers={
                "Content-Type": "application/x-www-form-urlencoded",
                "User-Agent": "bacon-setup/1.0 (CLI login)",
            },
            method="POST",
        )
        try:
            with urllib.request.urlopen(req, timeout=15) as resp:
                tokens = json.loads(resp.read())
        except urllib.error.HTTPError as http_err:
            body = http_err.read().decode(errors="replace")
            print(f"⚠️  Token exchange failed ({http_err.code}): {body}")
            return None

        id_token = tokens.get("id_token", "")
        if not id_token:
            print("⚠️  No id_token in response. Using anonymous ID.")
            return None

        # Decode JWT payload — obtained directly from Clerk over HTTPS, no sig check needed
        seg = id_token.split(".")[1]
        seg += "=" * (4 - len(seg) % 4)
        payload = json.loads(base64.urlsafe_b64decode(seg))

        clerk_id = payload.get("sub", "")
        if not clerk_id.startswith("user_"):
            print(f"⚠️  Unexpected sub: {clerk_id!r}. Using anonymous ID.")
            return None

        print(f"✅ Connected as {clerk_id}")
        return clerk_id

    except Exception as e:
        print(f"⚠️  Login failed ({e}). Using anonymous ID.")
        return None


def cmd_status():
    cfg = load_json(CONFIG_FILE, None)
    if not cfg:
        print("Bacon is not set up. Run: bacon-setup init")
        return
    settings = load_json(CLAUDE_SETTINGS, {})
    sl = settings.get("statusLine", {})
    sl_cmd = sl.get("command", "") if isinstance(sl, dict) else ""
    sl_on = "bacon-statusline" in json.dumps(sl)

    # Extract configured style from the command string if present
    sl_style = None
    if sl_on and "--style" in sl_cmd:
        parts = sl_cmd.split()
        try:
            sl_style = parts[parts.index("--style") + 1]
        except (ValueError, IndexError):
            pass

    spinner_on = cfg.get("spinner_enabled", False)
    print("🥓 Bacon setup status")
    print(f"  Config:     {'✅ present' if cfg else '❌ missing'}")
    print(f"  Active:     {cfg.get('active')}")
    print(f"  Surface:    {cfg.get('surface')}")
    if sl_on:
        style_str = f"  (style: {sl_style})" if sl_style else ""
        print(f"  Statusline: ✅ enabled{style_str}")
    else:
        print("  Statusline: ❌ not enabled  "
              "(run: bacon-setup statusline-enable)")
    print(f"  Spinner:    {'✅ enabled' if spinner_on else '❌ not enabled'}")


def cmd_init(user_id=None):
    BACON_DIR.mkdir(exist_ok=True)
    cfg = load_json(CONFIG_FILE, {})
    resolved_id = user_id or cfg.get("user_id") or f"dev-{uuid.uuid4().hex[:12]}"
    cfg["user_id"] = resolved_id
    cfg.setdefault("active", True)
    cfg.setdefault("frequency_tier", "standard")
    cfg.setdefault("frequency", 10)
    cfg.setdefault("profile_tier", "anonymous")
    cfg.setdefault("surface", "cards")
    cfg.setdefault("blocked_categories", [])
    cfg.setdefault("blocked_advertisers", [])
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))
    print(f"✅ Config ready at {CONFIG_FILE} (user_id={cfg['user_id']})")


def cmd_statusline_enable(style):
    if not CLAUDE_SETTINGS.exists():
        CLAUDE_SETTINGS.parent.mkdir(parents=True, exist_ok=True)
        settings = {}
    else:
        settings = load_json(CLAUDE_SETTINGS, {})

    existing = settings.get("statusLine")

    # Already enabled? (idempotent)
    if existing and "bacon-statusline" in json.dumps(existing):
        print("Bacon statusline already enabled.")
        return

    # Wrap-don't-clobber: if a statusline exists, preserve it and chain ours after.
    wrap_cmd = None
    if existing and existing.get("type") == "command" and existing.get("command"):
        SL_BACKUP.write_text(json.dumps(existing, indent=2))
        wrap_cmd = existing["command"]
        print(f"↪ Preserving your existing statusline (backed up to {SL_BACKUP})")

    settings["statusLine"] = {
        "type": "command",
        "command": bacon_command(style, wrap=wrap_cmd),
        "refreshInterval": 1,
    }
    CLAUDE_SETTINGS.write_text(json.dumps(settings, indent=2))
    print(f"✅ Bacon statusline enabled (style={style}). "
          f"It appears on your next interaction with Claude Code.")


def cmd_statusline_disable():
    if not CLAUDE_SETTINGS.exists():
        print("No settings.json found."); return
    settings = load_json(CLAUDE_SETTINGS, {})
    sl = settings.get("statusLine", {})
    if "bacon-statusline" not in json.dumps(sl):
        print("Bacon statusline is not enabled."); return

    # Restore the original statusline if we backed one up, else remove entirely.
    if SL_BACKUP.exists():
        settings["statusLine"] = load_json(SL_BACKUP, {})
        SL_BACKUP.unlink()
        print("✅ Restored your original statusline.")
    else:
        settings.pop("statusLine", None)
        print("✅ Removed the Bacon statusline (you had none before).")
    CLAUDE_SETTINGS.write_text(json.dumps(settings, indent=2))


def cmd_spinner_enable(style):  # noqa: ARG001 — style accepted for symmetry, ignored
    """Enable the spinnerVerbs ad surface (thinking-verb ad)."""
    if not CONFIG_FILE.exists():
        print("Bacon is not set up. Run: bacon-setup init first.")
        return
    cfg = load_json(CONFIG_FILE, {})
    if cfg.get("spinner_enabled"):
        print("Bacon spinner already enabled.")
        return
    cfg["spinner_enabled"] = True
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))
    print("✅ Bacon spinner (thinking-verb ad) enabled.")
    print("   The sponsored thinking verb will appear from your next Claude Code session.")
    print("   To disable: bacon-setup spinner-disable")


def cmd_spinner_disable():
    """Disable the spinnerVerbs ad surface and restore any original value."""
    cfg = load_json(CONFIG_FILE, {})
    if cfg:
        cfg["spinner_enabled"] = False
        CONFIG_FILE.write_text(json.dumps(cfg, indent=2))

    # Restore settings.json spinnerVerbs
    if CLAUDE_SETTINGS.exists():
        settings = load_json(CLAUDE_SETTINGS, {})
        if SPINNER_BACKUP.exists():
            original_sv = load_json(SPINNER_BACKUP, None)
            if original_sv is not None:
                settings["spinnerVerbs"] = original_sv
                print("✅ Restored your original spinnerVerbs.")
            SPINNER_BACKUP.unlink(missing_ok=True)
        else:
            settings.pop("spinnerVerbs", None)
            print("✅ Removed Bacon spinnerVerbs (you had none before).")
        CLAUDE_SETTINGS.write_text(json.dumps(settings, indent=2))

    # Clean up spinner state files
    for f in (SPINNER_BACKUP, SPINNER_AD_FILE):
        try:
            f.unlink(missing_ok=True)
        except Exception:
            pass


def cmd_uninstall():
    cmd_statusline_disable()
    cmd_spinner_disable()
    cfg = load_json(CONFIG_FILE, {})
    if cfg:
        cfg["active"] = False
        CONFIG_FILE.write_text(json.dumps(cfg, indent=2))
    print("✅ Bacon deactivated. Your balance is preserved and will still pay out.")


def main():
    args = sys.argv[1:]
    cmd = args[0] if args else "status"

    def opt(name, default=None):
        return args[args.index(name) + 1] if name in args else default

    if cmd == "status":
        cmd_status()
    elif cmd == "init":
        cmd_init(opt("--user-id"))
    elif cmd == "statusline-enable":
        cmd_statusline_enable(opt("--style", "marquee"))
    elif cmd == "statusline-disable":
        cmd_statusline_disable()
    elif cmd == "spinner-enable":
        cmd_spinner_enable(opt("--style", "default"))
    elif cmd == "spinner-disable":
        cmd_spinner_disable()
    elif cmd == "uninstall":
        cmd_uninstall()
    elif cmd == "login":
        clerk_id = cmd_login()
        if clerk_id:
            cmd_init(user_id=clerk_id)
    else:
        print(__doc__)


if __name__ == "__main__":
    main()
